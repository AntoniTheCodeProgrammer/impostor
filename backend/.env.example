# Skopiuj ten plik jako .env i uzupełnij wartościami

# Turso (libSQL) – URL bazy danych i token autoryzacyjny
# Token wygenerujesz poleceniem: turso db tokens create impostor
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Sekret do tworzenia konta admina (endpoint /admin/seed)
ADMIN_SEED_SECRET=impostor-secret
